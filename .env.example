ARTICLE_WRITER_HOST=127.0.0.1
ARTICLE_WRITER_PORT=8000
ARTICLE_WRITER_DATABASE_URL=sqlite:///./data/article_writer.db
ARTICLE_WRITER_SCHEDULE_HOUR=9
ARTICLE_WRITER_SCHEDULE_MINUTE=0
# Background scheduler: default off (manual via "Run Now" / run-once). Set to true to enable the daily run at SCHEDULE_HOUR/MINUTE.
ARTICLE_WRITER_SCHEDULER_ENABLED=
ARTICLE_WRITER_SINCE_HOURS=72
ARTICLE_WRITER_TOP_N=10
ARTICLE_WRITER_DRAFT_COUNT=3
ARTICLE_WRITER_DEDUP_DAYS=21
# Source enable flags, queries, feeds, keywords, and weights now live in sources.json.
ARTICLE_WRITER_LLM_OPTIONS=azure/gpt-4o,google/gemini-2.5-pro
ARTICLE_WRITER_GEMINI_API_KEY=
ARTICLE_WRITER_AZURE_OPENAI_API_KEY=
ARTICLE_WRITER_AZURE_OPENAI_ENDPOINT=
ARTICLE_WRITER_AZURE_OPENAI_API_VERSION=
ARTICLE_WRITER_GITHUB_TOKEN=
ARTICLE_WRITER_PRODUCT_HUNT_TOKEN=
# Path to a custom Twitter/X system prompt file (default: prompts/twitter_system_prompt.txt)
ARTICLE_WRITER_TWITTER_PROMPT_FILE=
# Path to a custom LinkedIn system prompt file (default: prompts/linkedin_system_prompt.txt)
ARTICLE_WRITER_LINKEDIN_PROMPT_FILE=
ARTICLE_WRITER_LOG_DIR=data/logs
ARTICLE_WRITER_LOG_LEVEL=INFO
