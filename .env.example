ARTICLE_WRITER_HOST=127.0.0.1
ARTICLE_WRITER_PORT=8000
ARTICLE_WRITER_DATABASE_URL=sqlite:///./data/article_writer.db
ARTICLE_WRITER_SCHEDULE_HOUR=9
ARTICLE_WRITER_SCHEDULE_MINUTE=0
ARTICLE_WRITER_SINCE_HOURS=72
ARTICLE_WRITER_TOP_N=5
ARTICLE_WRITER_DRAFT_COUNT=3
ARTICLE_WRITER_DEDUP_DAYS=21
ARTICLE_WRITER_ENABLE_HACKERNEWS=true
ARTICLE_WRITER_ENABLE_REDDIT=true
ARTICLE_WRITER_ENABLE_GITHUB=true
ARTICLE_WRITER_ENABLE_PRODUCT_HUNT=false
ARTICLE_WRITER_ENABLE_RSS=true
ARTICLE_WRITER_ENABLE_ARXIV=true
ARTICLE_WRITER_ENABLE_DEEPMIND=true
ARTICLE_WRITER_ENABLE_LOBSTERS=true
ARTICLE_WRITER_RSS_FEEDS=https://openai.com/news/rss.xml,https://huggingface.co/blog/feed.xml,https://simonwillison.net/atom/everything/,https://lastweekin.ai/feed,https://www.deeplearning.ai/the-batch/feed/
ARTICLE_WRITER_REDDIT_SUBREDDITS=MachineLearning,LocalLLaMA,artificial
ARTICLE_WRITER_KEYWORDS=ai,agent,agents,llm,model,models,openai,anthropic,gemini,claude,chatgpt,benchmark,inference,rag,robotics,multimodal
ARTICLE_WRITER_SOURCE_WEIGHTS=hackernews:1.0,reddit:0.9,github:1.1,product_hunt:1.0,rss:0.8,arxiv:1.2,deepmind:0.9,lobsters:0.85
ARTICLE_WRITER_LLM_OPTIONS=local-template,google/gemini-2.5-pro
ARTICLE_WRITER_GEMINI_API_KEY=
ARTICLE_WRITER_GITHUB_TOKEN=
ARTICLE_WRITER_PRODUCT_HUNT_TOKEN=
# Path to a custom Twitter/X system prompt file (default: prompts/twitter_system_prompt.txt)
ARTICLE_WRITER_TWITTER_PROMPT_FILE=
# Path to a custom LinkedIn system prompt file (default: prompts/linkedin_system_prompt.txt)
ARTICLE_WRITER_LINKEDIN_PROMPT_FILE=
